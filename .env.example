# ========================================
# TELEGRAM BOT CONFIGURATION
# ========================================

# Токен Telegram-бота (получи у @BotFather)
# Создай бота: открой @BotFather в Telegram, отправь /newbot
BOT_TOKEN=your_telegram_bot_token_here

# ========================================
# CHUTES AI CONFIGURATION
# ========================================

# API ключ Chutes (создай в dashboard.chutes.ai)
CHUTES_API_KEY=your_chutes_api_key_here

# URL API Chutes (по умолчанию используется публичный LLM endpoint)
CHUTES_API_URL=https://llm.chutes.ai/v1/chat/completions

# Имя модели (замени на свой chute URL или model name)
MODEL_NAME=default-model
